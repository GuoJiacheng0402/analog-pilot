# ============================================================================
#  analog-pilot —— 华南理工大学微电子学院 EDA 服务器连接配置模板
# ============================================================================
#
#  用法：
#     cp .env.example ~/.apilot/.env      # 或置于项目根目录
#     # 然后将下列占位符替换为实际值
#
#  安全提醒：填入真实主机/账号后，本文件含敏感信息，请勿提交至 git
#  （项目 .gitignore 已忽略 .env），亦请勿在公开文档或截图中暴露真实
#  IP、端口、学号、密码。
# ============================================================================

# --- 必填：EDA 服务器（校园网内可直连，无需跳板机）----------------------
#  将 <EDA_SERVER_IP> 替换为实验室/课程公告提供的服务器地址，
#  将 <YOUR_STUDENT_ID> 替换为服务器登录账号（学号）。
APILOT_REMOTE_HOST=<EDA_SERVER_IP>
APILOT_REMOTE_USER=<YOUR_STUDENT_ID>

# --- 端口：留空即可，桥接会按用户名哈希自动分配本地/远端端口 ------------
#  仅在多人共用同一台机或端口冲突时才需手动指定，故此处不写死。
# APILOT_REMOTE_PORT=
# APILOT_LOCAL_PORT=

# --- 【SCUT 必需】关闭 SSH ControlMaster -------------------------------
#  说明：在微电子学院服务器上启用 ControlMaster 时，桥接探测远端 Python 解释器
#  会返回空字符串，报 "No Python interpreter found ... Detection output: ''"。
#  关闭后仅每次新会话首次握手增加 1~2 秒，功能正常。详见 docs/02_常见问题与排错.md。
APILOT_DISABLE_CONTROL_MASTER=true

# --- 【SCUT 建议】将临时工作目录从 /tmp 移至稳定的家目录 ---------------
#  说明：/tmp 在服务器重启后会被清空，导致已部署的 daemon 文件丢失。
#  指向家目录下的固定目录即可（桥接首次启动时会自动创建）。
APILOT_REMOTE_SCRATCH_ROOT=/SM01/home/<grade>/<YOUR_STUDENT_ID>/.apilot

# --- Spectre 独立通道（可选）------------------------------------------
#  纯 SKILL 模式（在 Virtuoso 中运行仿真、读写 schematic/layout）下应留空：
#  SKILL 在 Virtuoso 主进程内执行，不依赖远端 shell 的 PATH。
#
#  仅当需要使用桥接的「独立 Spectre 通道」直接运行手写 netlist 时才需要此项，
#  且必须指向一个 csh 语法的环境脚本（学校的 bashrc_cds 为 bash 语法，不能
#  直接填写）。本项目在 docs/templates/cadence_env.csh.example 提供了可改写的
#  csh 模板。详见 docs/02_常见问题与排错.md 中「APILOT_CADENCE_CSHRC 填写 bashrc_cds」一节。
# APILOT_CADENCE_CSHRC=/SM01/home/<grade>/<YOUR_STUDENT_ID>/.apilot_cadence.csh

# ============================================================================
#  多服务器（multi-profile）：存在多台机器时，可添加 profile 后缀。
#  以 `apilot start -p lab2` 切换。后缀大小写敏感。
# ----------------------------------------------------------------------------
# APILOT_REMOTE_HOST_lab2=<ANOTHER_SERVER_IP>
# APILOT_REMOTE_USER_lab2=<YOUR_STUDENT_ID>
# APILOT_DISABLE_CONTROL_MASTER_lab2=true
# APILOT_REMOTE_SCRATCH_ROOT_lab2=/SM01/home/<grade>/<YOUR_STUDENT_ID>/.apilot
# ============================================================================
